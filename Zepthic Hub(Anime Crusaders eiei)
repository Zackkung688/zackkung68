-- Replace the existing getPlayerData function with this improved version
discordWebhook.getPlayerData = function()
    local dataPath = replicated:FindFirstChild("Player_Data")
    if not dataPath then return {} end

    local myData = dataPath:FindFirstChild(LocalPlayer.Name)
    if not myData then return {} end
    local stats = myData:FindFirstChild("Data")
    local items = myData:FindFirstChild("Items")
    if not stats or not items then return {} end

    -- ฟังก์ชันช่วยดึงจำนวนจาก Folder > Amount
    local function getItemAmount(folder)
        if folder and folder:IsA("Folder") then
            local amountObj = folder:FindFirstChild("Amount")
            if amountObj and (amountObj:IsA("IntValue") or amountObj:IsA("NumberValue")) then
                return amountObj.Value
            end
        end
        return 0
    end

    -- ดึง Level และ Experience
    local level = stats:FindFirstChild("Level") and stats.Level.Value or 1
    local currentExp = stats:FindFirstChild("Exp") and stats.Exp.Value or 0
    
    -- คำนวณ EXP ที่ต้องการสำหรับ Level ถัดไป (สูตรทั่วไป - อาจต้องปรับตามเกม)
    -- สูตรนี้อาจต้องปรับให้เหมาะกับเกม Anime Ranger X
    local function getRequiredExp(lvl)
        -- ตัวอย่างสูตร: Level * 1000 + (Level * 50) ^ 1.5
        -- คุณอาจต้องหาสูตรจริงจากเกม
        return math.floor(lvl * 1000 + (lvl * 50) ^ 1.2)
    end
    
    local requiredExp = getRequiredExp(level + 1)
    local levelDisplay = string.format("Level %d [%s/%s]", level, 
        tostring(currentExp), 
        tostring(requiredExp)
    )

    return {
        gems = stats:FindFirstChild("Gem") and stats.Gem.Value or 0,
        golds = stats:FindFirstChild("Gold") and stats.Gold.Value or 0,
        rcCells = stats:FindFirstChild("RCCells") and stats.RCCells.Value or 0,
        fallCurrency = stats:FindFirstChild("Fall Currency") and stats["Fall Currency"].Value or 0,
        traitReroll = getItemAmount(items:FindFirstChild("Trait Reroll")),
        level = level,
        experience = currentExp,
        levelDisplay = levelDisplay
    }
end

-- Replace the existing getRewards function with this improved version
discordWebhook.getRewards = function()
    local rewards = {}
    if not LocalPlayer:FindFirstChild("RewardsShow") then return rewards end

    task.wait(1) -- รอสักครู่ให้ RewardsShow อัพเดต

    local itemsFolder = replicated:WaitForChild("Player_Data"):WaitForChild(LocalPlayer.Name):WaitForChild("Items")

    -- ฟังก์ชันช่วยดึงจำนวนจาก Folder > Amount
    local function getItemAmount(folder)
        if folder and folder:IsA("Folder") then
            local amountObj = folder:FindFirstChild("Amount")
            if amountObj and (amountObj:IsA("IntValue") or amountObj:IsA("NumberValue")) then
                return amountObj.Value
            end
        end
        return 0
    end

    -- ฟังก์ชันกำหนดไอคอนตามชื่อ
    local function getIcon(name)
        name = name:lower()
        if name:find("gem") then
            return "💎 "
        elseif name:find("gold") then
            return "🪙 "
        elseif name:find("exp") then
            return "⭐ "
        elseif name:find("rccells") or name:find("cell") then
            return "🩸 "
        elseif name:find("fall") then
            return "🍁 "
        elseif name:find("trait") then
            return "🧩 "
        elseif name:find("portal") then
            return "🌀 "
        else
            return "🎁 "
        end
    end

    -- ดึง RewardsShow ทุก Folder
    for _, folder in pairs(LocalPlayer.RewardsShow:GetChildren()) do
        if folder:IsA("Folder") then
            local amountObj = folder:FindFirstChild("Amount")
            if amountObj and (amountObj:IsA("IntValue") or amountObj:IsA("NumberValue")) and amountObj.Value > 0 then
                local name = folder.Name
                local icon = getIcon(name)
                local rewardAmount = amountObj.Value

                -- จำนวนที่มีจริงจาก Items (รองรับ Folder ซ้อน) + รวมรางวัลที่จะได้
                local totalOwned = 0
                local itemFolder = itemsFolder:FindFirstChild(name)
                if itemFolder then
                    if itemFolder:FindFirstChild("Amount") then
                        totalOwned = getItemAmount(itemFolder)
                    else
                        for _, sub in pairs(itemFolder:GetChildren()) do
                            totalOwned = totalOwned + getItemAmount(sub)
                        end
                    end
                end

                -- สำหรับ Trait Reroll: แสดงจำนวนหลังได้รับรางวัล
                local finalAmount = totalOwned + rewardAmount

                -- ถ้าเป็น Gem / Gold / Exp ไม่ต้องใส่ [จำนวนที่มี]
                if name:lower():find("Gem") or name:lower():find("Gold") or name:lower():find("Exp") or name:lower():find("Fall Currency") then
                    table.insert(rewards, string.format("%s x%d %s", icon, rewardAmount, name))
                else
                    table.insert(rewards, string.format("%s x%d %s [%d]", icon, rewardAmount, name, finalAmount))
                end
            end
        end
    end

    return rewards
end

-- Replace the existing sendToDiscord function with this improved version
discordWebhook.sendToDiscord = function(resultData, rewardList, mapName, playTime)
    if not Settings.DiscordEnabled or not webhookSupported then
        return
    end

    local rewardText = (#rewardList > 0) and table.concat(rewardList, "\n") or "❌ No Rewards"

    local embed = {
        title = "# GAME IS COMPLETED?!🍀🎮",
        color = 0x99ff33,
        fields = {
            { 
                name = "Player", 
                value = string.format("%s\n%s", 
                    LocalPlayer.Name, 
                    resultData.levelDisplay or "Level N/A"
                ), 
                inline = false 
            },
            {
                name = "Result - ข้อมูล",
                value = string.format(
                    "**Map:** %s\n**Time:** %s\n💎 Gems: **%s**\n🪙 Gold: **%s**\n🩸 RC.Cells: **%s**\n🍁 Fall Currency: **%s**\n🧩 Trait Reroll: **%s**",
                    mapName,
                    playTime,
                    tostring(resultData.gems),
                    tostring(resultData.golds),
                    tostring(resultData.rcCells),
                    tostring(resultData.fallCurrency),
                    tostring(resultData.traitReroll)
                ),
                inline = false
            },
            {
                name = "Rewards - ของรางวัล",
                value = rewardText,
                inline = false
            }
        },
        footer = { text = "discord.gg/Jaabook  •  " .. os.date("%H:%M:%S") },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
    }

    local payload = HttpService:JSONEncode({
        username = "Zepthic hub",
        avatar_url = "https://i.imgur.com/your-bot-avatar.gif",
        embeds = {embed}
    })

    local success, response = pcall(function()
        return http_request({
            Url = Settings.DiscordURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = payload
        })
    end)

    if success then
        print("✅🌈 Webhook ส่งสำเร็จพร้อมสีสวย!")
    else
        warn("❌ Webhook ส่งไม่สำเร็จ: " .. tostring(response))
    end
end

-- Setup Discord Event Listener พร้อมระบบจับเวลา
if webhookSupported then
    spawn(function()
        -- ฟัง GameStart (เริ่มจับเวลา)
        local gameStartConnection
        gameStartConnection = RunService.Heartbeat:Connect(function()
            if workspace:FindFirstChild('Building') and not GameTimer.isGameRunning then
                GameTimer:Start()
            end
        end)

        -- ฟัง GameEnd (หยุดจับเวลาและส่ง webhook)
        local gameEndRemote = replicated:WaitForChild("Remote"):WaitForChild("Client"):WaitForChild("UI"):WaitForChild("GameEndedUI")
        gameEndRemote.OnClientEvent:Connect(function()
            if not Settings.DiscordEnabled then return end
            
            local currentTime = tick()
            
            -- ป้องกันการส่งซ้ำใน 15 วินาที
            if currentTime - lastSentTime < COOLDOWN_TIME then
                print("⏳ ยังไม่ครบ cooldown, ข้ามการส่ง webhook")
                return
            end
            
            lastSentTime = currentTime
            local playTime = GameTimer:Stop() -- หยุดจับเวลาและเก็บค่า
            print("🎯 เกมจบ! กำลังส่ง webhook...")

            -- รอให้ข้อมูลอัพเดตก่อนส่ง
            task.spawn(function()
                local resultData = discordWebhook.getPlayerData()
                local rewards = discordWebhook.getRewards()
                local worldInfo = GameDataSystem.GetWorldInfo()
                local mapName = worldInfo.FullMapName

                discordWebhook.sendToDiscord(resultData, rewards, mapName, playTime)
            end)
        end)
    end)
end

