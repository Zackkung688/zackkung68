-- Game Timer System
local GameTimer = {
	startTime = 0,
	endTime = 0,
	isGameRunning = false
}

function GameTimer:Start()
	self.startTime = tick()
	self.isGameRunning = true
	print("⏰ Started game timer...")
end

function GameTimer:Stop()
	if self.isGameRunning then
		self.endTime = tick()
		self.isGameRunning = false
		print("⏱️ Stopped game timer")
		return self:GetPlayTime()
	end
	return "Unknown"
end

function GameTimer:GetPlayTime()
	if self.startTime > 0 then
		local duration = (self.endTime > 0 and self.endTime or tick()) - self.startTime
		local minutes = math.floor(duration / 60)
		local seconds = math.floor(duration % 60)
		return string.format("%02d:%02d", minutes, seconds)
	end
	return "00:00"
end

