-- Function to send Discord embed
discordWebhook.sendToDiscord = function(gameData, playTime)
    if not Settings.DiscordEnabled or not webhookSupported then
        return
    end

    local currentTime = tick()
    if currentTime - lastSentTime < COOLDOWN_TIME then
        print("⏳ Cooldown active, skipping webhook")
        return
    end
    
    lastSentTime = currentTime

    local embed = {
        title = "# ANIME CRUSADERS COMPLETED! 🎮⚔️",
        color = 0x00ff88,
        fields = {
            { name = "👤 Player", value = LocalPlayer.Name, inline = false },
            {
                name = "Game Info",
                value = string.format(
                    "**Map:** %s\n**Time:** %s\n💎 Gems: **%s**\n🪙 Coins: **%s**",
                    gameData.fullMapName,
                    playTime,
                    tostring(gameData.gems),
                    tostring(gameData.coins)
                ),
                inline = false
            }
        },
        footer = { text = "Zepthic AC  •  " .. os.date("%H:%M:%S") },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
    }

    local payload = HttpService:JSONEncode({
        username = "Zepthic AC Bot",
        avatar_url = "https://i.imgur.com/your-bot-avatar.gif",
        embeds = {embed}
    })

    local success, response = pcall(function()
        return http_request({
            Url = Settings.DiscordURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = payload
        })
    end)

    if success then
        print("✅ Webhook sent successfully!")
    else
        warn("❌ Webhook failed: " .. tostring(response))
    end
end

