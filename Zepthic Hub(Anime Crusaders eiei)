			local info = string.format(
				"Script: Zepthic AC v1.0\nPlayer: %s\nGame Timer: %s\nWebhook: %s\nMarcos Available: %d\nCurrent Pod: %s\nCurrent Level: %s",
				LocalPlayer.Name,
				GameTimer.isGameRunning and "Running" or "Stopped",
				webhookSupported and "Supported" or "Not Supported",
				#marco,
				Settings.Pod or "None",
				Settings.Level or "None"
			)
			
			Fluent:Notify({
				Title = "Script Information",
				Content = info,
				Duration = 5
			})
		end
	})
	
	Tabs.Settings:AddButton({
		Title = "Show Current Game State",
		Description = "Display current game information",
		Callback = function()
			local gameInfo = string.format(
				"Selected Pod: %s\nSelected Level: %s\nDifficulty: %s\nChallenge Pod: %s\nGame Running: %s",
				_G.Pod or "None",
				_G.Level or "None", 
				_G.Difficulty or "None",
				_G.ChallengePod or "None",
				GameTimer.isGameRunning and "Yes" or "No"
			)
			
			Fluent:Notify({
				Title = "Game State",
				Content = gameInfo,
				Duration = 5
			})
		end
	})
	
	Tabs.Settings:AddSection("Game Remotes Info")
	Tabs.Settings:AddParagraph({
		Title = "Available Remotes:",
		Content = "• request_join_lobby - Join pods\n• request_lock_level - Lock level selection\n• request_start_game - Start the game\n• set_game_finished_vote - Vote retry/next\n• spawn_unit - Place units (Marco)\n• upgrade_unit_ingame - Upgrade units (Marco)\n• cycle_priority - Change targeting (Marco)\n• sell_unit_ingame - Sell units (Marco)"
	})
