-- ฟังก์ชันดึงข้อมูลโลกและเลเวล
function GameDataSystem.GetWorldInfo()
	local success, result = pcall(function()
		-- พยายามดึงข้อมูลจาก ReplicatedStorage
		local GameWorld = replicated.Shared.Info.GameWorld
		local WorldData = require(GameWorld.World)
		local LevelsData = require(GameWorld.Levels)
		
		local worldId = replicated.Values.Game.World.Value
		local levelId = replicated.Values.Game.Level.Value
		local gamemode = replicated.Values.Game.Gamemode.Value
		local difficulty = replicated.Values.Game.Difficulty.Value

		local worldName = WorldData[worldId].Name
		local levelName = LevelsData[worldId][levelId].Name

		return {
			WorldName = worldName,
			LevelName = levelName,
			Gamemode = gamemode,
			Difficulty = difficulty,
			FullMapName = worldName .. " - " .. levelName .. " (" .. difficulty .. ")"
		}
	end)
	
	if success and result then
		return result
	else
		-- ถึงดึงไม่ได้ ให้ลอง fallback
		return GameDataSystem.GetWorldInfoFallback()
	end
end

function GameDataSystem.GetWorldInfoFallback()
	local success, result = pcall(function()
		-- ลองดึงจาก PlayRoom หรือที่อื่น
		local playRoom = replicated.PlayRoom:FindFirstChild(LocalPlayer.Name)
		if playRoom then
			local world = playRoom.World.Value or "Unknown World"
			local chapter = playRoom.Chapter.Value or "Unknown Chapter"
			local difficulty = playRoom.Difficulty.Value or "Unknown Difficulty"
			
			return {
				WorldName = world,
				LevelName = chapter,
				Gamemode = "Story",
				Difficulty = difficulty,
				FullMapName = world .. " - " .. chapter .. " (" .. difficulty .. ")"
			}
		end
		
		return {
			WorldName = "Unknown World",
			LevelName = "Unknown Level", 
			Gamemode = "Unknown Mode",
			Difficulty = "Unknown",
			FullMapName = "Unknown Map"
		}
	end)
	
	return result or {
		WorldName = "Unknown World",
		LevelName = "Unknown Level",
		Gamemode = "Unknown Mode", 
		Difficulty = "Unknown",
		FullMapName = "Unknown Map"
	}
end

-- ดึง Story และ World List ที่มีอยู่
function GameDataSystem.GetAvailableWorlds()
	local worlds = {}
	local success = pcall(function()
		local GameWorld = replicated.Shared.Info.GameWorld
		local WorldData = require(GameWorld.World)
		
		for worldId, worldInfo in pairs(WorldData) do
			table.insert(worlds, {
				id = worldId,
				name = worldInfo.Name
			})
		end
	end)
	
	if not success or #worlds == 0 then
		-- Fallback: ใช้ข้อมูลจาก GUI เก่า
		for i,v in pairs(game:GetService("Players").LocalPlayer.PlayerGui.PlayRoom.Main.GameStage.Main.Base.Story.ScrollingFrame:GetChildren()) do
			if v:IsA("TextButton") and v.Name ~= "UIListLayout" then
				table.insert(worlds, {
					id = v.Name,
					name = v.Name
				})
			end
		end
	end
	
	return worlds
end

function GameDataSystem.GetAvailableChapters(worldId)
	local chapters = {}
	local success = pcall(function()
		local GameWorld = replicated.Shared.Info.GameWorld  
		local LevelsData = require(GameWorld.Levels)
		
		if LevelsData[worldId] then
			for levelId, levelInfo in pairs(LevelsData[worldId]) do
				table.insert(chapters, {
					id = levelId,
					name = levelInfo.Name
				})
			end
		end
	end)
	
	if not success or #chapters == 0 then
		-- Fallback: ใช้หมายเลขธรรมดา
		for i = 1, 10 do
			table.insert(chapters, {
				id = tostring(i),
				name = "Chapter " .. i
			})
		end
	end
	
	return chapters
end

