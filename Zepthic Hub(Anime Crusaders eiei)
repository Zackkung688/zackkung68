			Title = "⚠️ Warning",
			Content = "Your executor does not support HTTP requests. Discord webhook functionality will not work."
		})
	else
		Tabs.Discord:AddParagraph({
			Title = "✅ HTTP Support",
			Content = "Your executor supports HTTP requests. Discord webhook is ready to use!"
		})
	end
	
	Toggle(Tabs.Discord, "Enable Discord Notifications", "DiscordEnabled")
	
	Tabs.Discord:AddInput("DiscordURL", {
        Title = "Discord Webhook URL",
        Default = Settings.DiscordURL or "https://discord.com/api/webhooks/YOUR_WEBHOOK_URL",
        Placeholder = "Paste your Discord webhook URL here",
        Numeric = false, 
        Finished = false,
        Callback = function(Value)
            Settings.DiscordURL = Value
			_G.DiscordURL = Value
			saveConfig()
        end
    })
	
	Tabs.Discord:AddButton({
		Title = "Test Webhook",
		Description = "Send a test message to Discord",
		Callback = function()
			if not Settings.DiscordEnabled then
				Fluent:Notify({
					Title = "Discord Webhook",
					Content = "Please enable Discord Webhook first!",
					Duration = 3
				})
				return
			end
			
			if not webhookSupported then
				Fluent:Notify({
					Title = "Discord Webhook", 
					Content = "Your executor doesn't support HTTP requests!",
					Duration = 3
				})
				return
			end
			
			local gameData = discordWebhook.getGameInfo()
			local playTime = GameTimer:GetPlayTime()
			
			local testEmbed = {
				title = "🧪 Test Message from Zepthic AC",
				description = "This is a test message to verify webhook functionality!",
				color = 0x00ff00,
				fields = {
					{ name = "👤 Player", value = LocalPlayer.Name, inline = true },
					{ name = "🎮 Game", value = "Anime Crusaders", inline = true },
					{ name = "🗺️ Current Setup", value = gameData.fullMapName, inline = true },
					{ name = "⏰ Session Time", value = playTime, inline = true },
					{ name = "✨ Status", value = "Webhook Working Perfectly!", inline = true }
				},
				footer = { text = "Zepthic AC Script  •  " .. os.date("%H:%M:%S") },
				timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
			}

			local payload = HttpService:JSONEncode({
				username = "🤖 Zepthic AC Test Bot",
				avatar_url = "https://i.imgur.com/your-bot-avatar.gif",
				embeds = {testEmbed}
			})

			local success, response = pcall(function()
				return http_request({
					Url = Settings.DiscordURL,
					Method = "POST",
					Headers = {["Content-Type"] = "application/json"},
					Body = payload
				})
			end)

			if success then
				Fluent:Notify({
					Title = "Discord Webhook",
					Content = "✅ Test message sent successfully!",
					Duration = 3
				})
			else
				Fluent:Notify({
					Title = "Discord Webhook",
					Content = "❌ Failed to send test message. Check your URL!",
					Duration = 5
				})
			end
		end
	})
	
	Tabs.Discord:AddSection("Webhook Information")
	Tabs.Discord:AddParagraph({
		Title = "📝 How to get Discord Webhook URL:",
		Content = "1. Go to your Discord server\n2. Right-click on a text channel\n3. Select 'Edit Channel'\n4. Go to 'Integrations' tab\n5. Click 'Create Webhook'\n6. Copy the webhook URL and paste it above"
	})
	
	Tabs.Discord:AddParagraph({
		Title = "🎯 Features:",
		Content = "• Game completion notifications\n• Pod and level tracking\n• Play time measurement\n• Player stats display\n• Anti-spam protection\n• Beautiful embed messages"
	})
	
	Tabs.Discord:AddSection("Webhook Preview")
	Tabs.Discord:AddButton({
		Title = "Preview Current Game Data",
		Description = "See what data will be sent to Discord",
		Callback = function()
			local gameData = discordWebhook.getGameInfo()
			local playTime = GameTimer:GetPlayTime()
			
			local previewText = string.format(
				"Pod: %s\nLevel: %s\nDifficulty: %s\nTime: %s",
				gameData.pod,
				gameData.level,
				gameData.difficulty,
				playTime
			)
			
			Fluent:Notify({
				Title = "Discord Preview",
				Content = previewText,
				Duration = 5
			})
		end
	})
	
	-- Settings Tab
	Tabs.Settings:AddSection("Performance")
	Toggle(Tabs.Settings, "White Screen (Performance)", "WhiteScreen")
	
	Tabs.Settings:AddSection("Debug Information")
	Tabs.Settings:AddButton({
		Title = "Show Script Info",
		Description = "Display current script status",
