    local function runFarmLoop()
        if _farmRunning then return end
        _farmRunning=true
        while _G.AutoFarm or _G.AutoBossFarm do
            local ok,err=pcall(function()
                if _G.AutoBossFarm then
                    local bossNpc,bossName=findAnyBossAlive()
                    if bossNpc then
                        local targetIsland=IslandMap[bossName]
                        local bRoot=getRoot(bossNpc)
                        if bRoot and Root then
                            local dist=(Root.Position-bRoot.Position).Magnitude
                            if dist>800 or not nearIsland(targetIsland) then
                                safeTP(targetIsland)
                                local waited=0
                                repeat
                                    waited = waited + task.wait(0.5)
                                    bossNpc=getNearestAlive(bossName)
                                    bRoot=bossNpc and getRoot(bossNpc)
                                until (bRoot and Root and (Root.Position-bRoot.Position).Magnitude<800) or waited>=6
                            end
                        end
                        bossNpc=getNearestAlive(bossName)
                        if bossNpc and alive(bossNpc) then killTarget(bossNpc) end
                        task.wait(0.2)
                        return
                    end
                    if not _G.AutoFarm then task.wait(1.5) return end
                end
                if _G.AutoFarm then
                    local list=_G.SelectedMonsters or {}
                    if #list==0 then task.wait(0.8) return end
                    local targetNpc,targetName=nil,nil
                    for _,mName in ipairs(list) do
                        local npc=getNearestAlive(mName)
                        if npc then targetNpc=npc targetName=mName break end
                    end
                    if targetNpc then
                        local nRoot=getRoot(targetNpc)
                        if nRoot and Root and (Root.Position-nRoot.Position).Magnitude>1200 then
                            safeTP(IslandMap[targetName])
                            task.wait(0.5)
                            targetNpc=getNearestAlive(targetName)
                        end
                        if targetNpc then killTarget(targetNpc) end
                    else
                        local first=list[1]
                        if first and IslandMap[first] then safeTP(IslandMap[first]) end
                        task.wait(1.5)
                    end
                end
            end)
            if not ok then warn("[JxckyzHub] Farm Error:", tostring(err)) task.wait(0.5) end
            task.wait()
        end
        stopLock()
        _farmRunning=false
    end

