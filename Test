    local function safeTP(island)
        if not island then return end
        stopLock()
        task.wait(0.05)
        teleportIsland(island)
        task.wait(2)
    end

    local function nearIsland(island)
        local folder=workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("EnemyNpcs") and workspace.Game.EnemyNpcs:FindFirstChild(island)
        if not folder or not Root then return true end
        for _,v in ipairs(folder:GetChildren()) do
            local r=v:FindFirstChild("HumanoidRootPart") or v.PrimaryPart
            if r then return (Root.Position-r.Position).Magnitude<1000 end
        end
        return false
    end

    local function killTarget(npc)
        if not alive(npc) then return end
        local nr=getRoot(npc) if not nr then return end
        _lockCF=farmCF(nr)
        startLock()
        while alive(npc) and (_G.AutoFarm or _G.AutoBossFarm) do
            if _G.AutoBossFarm and not table.find(BossList,npc.Name) then
                local bCheck=findAnyBossAlive()
                if bCheck then break end
            end
            local nr2=getRoot(npc)
            if nr2 then _lockCF=farmCF(nr2) end
            hit()
            skills()
            if (_G.AttackSpeed or 0)>0 then task.wait(_G.AttackSpeed) else task.wait() end
        end
        stopLock()
    end

    local _farmRunning=false

    local function stopFarm()
        stopLock()
        _farmRunning=false
