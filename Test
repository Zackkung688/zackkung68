local function httpGet(url)
    local ok, res = pcall(game.HttpGet, game, url, true)
    if not ok then return nil, "Network error: "..tostring(res) end
    local ok2, data = pcall(HttpService.JSONDecode, HttpService, res)
    if not ok2 then return nil, "Bad response from server" end
    return data, nil
end
local function httpPost(url, body)
    local fn = request or (http and http.request) or (syn and syn.request)
    if not fn then return nil, "POST not supported" end
    local ok, res = pcall(fn,{
        Url=url, Method="POST",
        Headers={["Content-Type"]="application/json"},
        Body=HttpService:JSONEncode(body),
    })
    if not ok then return nil, "POST error: "..tostring(res) end
    local ok2, data = pcall(HttpService.JSONDecode, HttpService, res.Body or "")
    if not ok2 then return nil, "Bad POST response" end
    return data, nil
end
local function checkKey(key)
    local url = BASE_URL.."/api/keys/check"
        .."?post="..HttpService:UrlEncode(POST_SLUG)
        .."&key=" ..HttpService:UrlEncode(key)
        .."&hwid="..HttpService:UrlEncode(HWID)
    local data, err = httpGet(url)
    if not data then return false, err end
    if data.status=="error" then return false, data.message or "Server error" end
    if not data.valid then return false, data.message or "Key invalid or expired" end
    if data.hwid_bound and data.hwid_match==false then
        return false, "HWID mismatch — key is bound to another device"
    end
    return true, data
end
local function bindHwid(key)
    local _,err = httpPost(BASE_URL.."/api/keys/set-hwid",{
        post=POST_SLUG, api_key=API_KEY, key=key, hwid=HWID,
    })
    if err then warn("[jxckyz hub] bindHwid:", err) end
end

