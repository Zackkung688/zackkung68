    local function teleportIsland(isl)
        pcall(function() RS.Remotes.Events.TeleportToIslandRequest:FireServer(isl) end)
        task.wait(1.5)
        pcall(function()
            local parts=string.split(Crystals[isl] or "",".")
            local obj=game
            for i=2,#parts do obj=obj:FindFirstChild(parts[i]) if not obj then return end end
            if obj and obj:IsA("ProximityPrompt") then
                local par=obj.Parent
                local prim=(par and par:IsA("BasePart")) and par
                    or (par and par:IsA("Model") and (par.PrimaryPart or par:FindFirstChildWhichIsA("BasePart")))
                if prim and Root then Root.CFrame=prim.CFrame+Vector3.new(0,3,3) task.wait(0.15) end
                fireproximityprompt(obj,0)
            end
        end)
    end

