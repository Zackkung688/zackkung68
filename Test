    local function getNearestAlive(name)
        local island=IslandMap[name] if not island then return nil end
        local folder=WS:FindFirstChild("Game") and WS.Game:FindFirstChild("EnemyNpcs") and WS.Game.EnemyNpcs:FindFirstChild(island)
        if not folder then return nil end
        local best,bestDist=nil,math.huge
        local myPos=(Root and Root.Position) or Vector3.zero
        for _,v in ipairs(folder:GetChildren()) do
            if v.Name==name then
                local h=v:FindFirstChildOfClass("Humanoid")
                local r=v:FindFirstChild("HumanoidRootPart") or v.PrimaryPart
                if h and h.Health>0 and r then
                    local d=(r.Position-myPos).Magnitude
                    if d<bestDist then bestDist=d best=v end
                end
            end
        end
        return best
    end

    local function findAnyBossAlive()
        for _,name in ipairs(_G.SelectedBosses or {}) do
            local island=IslandMap[name]
            if island then
                local folder=WS:FindFirstChild("Game") and WS.Game:FindFirstChild("EnemyNpcs") and WS.Game.EnemyNpcs:FindFirstChild(island)
                if folder then
                    for _,v in ipairs(folder:GetChildren()) do
                        if v.Name==name then
                            local h=v:FindFirstChildOfClass("Humanoid")
                            if h and h.Health>0 then return v,name end
                        end
                    end
                end
            end
        end
        return nil,nil
    end

