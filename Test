            local model=WS.Game.ServiceNpcs.QuestGivers:FindFirstChild(npcName) if not model then return end
            local root=model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart") if not root then return end
            local dir=(Root.Position-root.Position).Unit
            Root.CFrame=CFrame.new(root.Position+dir*8+Vector3.new(0,3,0),root.Position)
            task.wait(0.2)
            for _,v in pairs(model:GetDescendants()) do
                if v:IsA("ProximityPrompt") then fireproximityprompt(v,0) task.wait(0.15) break end
            end
            RS.Remotes.ToggleQuestLoop:FireServer(1,2)
        end)
    end

