local function verifyAndLaunch(key, isAutoLoad)
    setStatus(isAutoLoad and "Auto-verifying saved key..." or "Checking key...")
    CheckBtn.Text="VERIFYING..."
    local valid,data=checkKey(key)
    if not valid then
        if isAutoLoad then
            clearSavedKey()
            setStatus("Saved key expired. Enter a new key.", true)
            notify("Saved key expired! Enter a new key.")
        else
            setStatus(tostring(data), true)
            notify(tostring(data))
        end
        CheckBtn.Text="VERIFY  &  ENTER"
        return
    end
    local exp=(data.expires_at and data.expires_at~="") and data.expires_at or "Never"
    setStatus("Valid  ·  Expires: "..exp)
    notify(isAutoLoad and "Auto-verified! Loading..." or "Key valid! Loading...")
    if not data.hwid_bound then bindHwid(key) end
    saveKeyToFile(key)
    _G.Key=key _G.loaderXlinkExecuted=true
    task.wait(0.5)
    tw(Frame,.2,{BackgroundTransparency=1})
    task.wait(0.25)
    Gui:Destroy()
    _G.loaderXlinkGuiInstance=nil
    task.wait(0.1)
    MainScript()
    CheckBtn.Text="VERIFY  &  ENTER"
end

local busy=false
local savedKey=loadSavedKey()
if savedKey then
    Input.Text=savedKey
    busy=true
    task.spawn(function() verifyAndLaunch(savedKey,true) busy=false end)
end

CheckBtn.MouseButton1Click:Connect(function()
    if busy then return end
    local key=Input.Text:gsub("%s+","")
    if key=="" then setStatus("Please enter your key.",true) return end
    busy=true
    task.spawn(function() verifyAndLaunch(key,false) busy=false end)
end)
