-- Helper Functions
local function Toggle(tab, title, setting)
	local toggle = tab:AddToggle(title, { 
		Title = title, 
		Default = Settings[setting] 
	})
	toggle:OnChanged(function(value)
		Settings[setting] = value
		_G[setting] = value
		saveConfig()
		if func[setting] then
			task.spawn(func[setting])
		end
	end)
	return toggle
end

local function Slider(tab, title, setting, min, max, default)
	local slider = tab:AddSlider(title, {
		Title = title,
		Min = min,
		Max = max,
		Default = Settings[setting] or default,
		Rounding = 1
	})
	slider:OnChanged(function(value)
		Settings[setting] = value
		saveConfig()
	end)
	return slider
end

