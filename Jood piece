--- สร้าง ESP สำหรับมอนสเตอร์
local function CreateESP(mob)
    if mob:FindFirstChild("ESP_UI") then return end
    local hum = mob:FindFirstChild("Humanoid") or mob:FindFirstChild("Enemy")
    local root = mob:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    local hl = Instance.new("Highlight", mob)
    hl.Name = "ESP_HL"
    hl.FillColor = Color3.fromRGB(255, 60, 60)
    hl.OutlineColor = Color3.new(1,1,1)
    hl.FillTransparency = 0.4

    local gui = Instance.new("BillboardGui", mob)
    gui.Name = "ESP_UI"
    gui.Adornee = root
    gui.Size = UDim2.fromScale(4,1.5)
    gui.StudsOffset = Vector3.new(0,4,0)
    gui.AlwaysOnTop = true

    local txt = Instance.new("TextLabel", gui)
    txt.Size = UDim2.fromScale(1,1)
    txt.BackgroundTransparency = 1
    txt.TextScaled = true
    txt.Font = Enum.Font.GothamBold
    txt.TextStrokeTransparency = 0
    
    task.spawn(function()
    while c().HighlightMob and hum.Health > 0 do
        txt.Text = mob.Name .. " | " .. math.floor((hum.Health/hum.MaxHealth)*100) .. "%"
        task.wait(0.1)
    end
    if gui then gui:Destroy() end
    if hl then hl:Destroy() end
end)
