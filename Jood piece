--- จัดรูปแบบตัวเลขให้อ่านง่าย (K, M, B, T)
local function FormatNumber(num) 
    if num >= 1e12 then 
        return string.format("%.2fT", num / 1e12) 
    elseif num >= 1e9 then 
        return string.format("%.2fB", num / 1e9) 
    elseif num >= 1e6 then 
        return string.format("%.2fM", num / 1e6) 
    else 
        return tostring(num) 
    end 
end

--- ดึงรายชื่อมอนสเตอร์ทั้งหมดในเกม
local function GetAllMobs() 
    local mobs = {} 
    for _, island in pairs(Workspace.Mobs:GetChildren()) do 
        for i, mob in ipairs(island:GetChildren()) do 
            if mob:IsA("Model") and (mob:FindFirstChild("Humanoid") or mob:FindFirstChild("Enemy")) then 
                if not table.find(mobs, mob.Name) then 
                    table.insert(mobs, mob.Name) 
                end 
            end 
        end 
    end 
    return mobs 
end

--- Teleport ตัวละครไปยังตำแหน่งที่กำหนด
local function Teleport(cf) 
    if Character and Character:FindFirstChild("HumanoidRootPart") then 
        Character.HumanoidRootPart.CFrame = cf 
    end 
end

--- หาเป้าหมายที่ใกล้ที่สุดจาก Path ที่กำหนด
local function InRaya(Path, condition) 
    local ClosestTarget = nil 
    local ShortestDistance = math.huge 
    for _, Object in pairs(Path) do 
        if condition(Object) then 
            local Distance = (Object:GetPivot().Position - RootPart.Position).Magnitude 
            if Distance < ShortestDistance then 
                ShortestDistance = Distance 
                ClosestTarget = Object 
            end 
        end 
    end 
    return ClosestTarget 
end

--- ดึงรายชื่อศัตรูทั้งหมดตามเกาะและมอนที่เลือก
local function GetAllEnemy() 
    local enemies = {} 
    if c().SelectedIsland and c().SelectedIsland ~= "All Islands" then 
        local island = Workspace.Mobs:FindFirstChild(c().SelectedIsland) 
        if island then 
            for _, mob in ipairs(island:GetChildren()) do 
                if mob:IsA("Model") then 
                    local humanoid = mob:FindFirstChild("Humanoid") or mob:FindFirstChild("Enemy") 
                    local rootPart = mob:FindFirstChild("HumanoidRootPart") 
                    if humanoid and rootPart and humanoid.Health > 0 then 
                        if c().SelectedMob == "All Mobs" or not c().SelectedMob or mob.Name == c().SelectedMob then 
                            table.insert(enemies, mob) 
                        end 
                    end 
                end 
            end 
        end 
    else 
        for _, island in pairs(Workspace.Mobs:GetChildren()) do 
            for _, mob in ipairs(island:GetChildren()) do 
                if mob:IsA("Model") then 
                    local humanoid = mob:FindFirstChild("Humanoid") or mob:FindFirstChild("Enemy") 
                    local rootPart = mob:FindFirstChild("HumanoidRootPart") 
                    if humanoid and rootPart and humanoid.Health > 0 then 
                        table.insert(enemies, mob) 
                    end 
                end 
            end 
        end 
    end 
    return enemies 
end

