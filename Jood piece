--- 🎯 AUTO FARM (ระบบฟาร์มมอนอัตโนมัติ)
func['AutoFarm'] = function() 
    while task.wait() do 
        xpcall(function() 
            if c().AutoFarm then 
                if c().SelectedIsland and c().SelectedIsland ~= "All Islands" then 
                    if IslandData[c().SelectedIsland] then
                        Teleport(CFrame.new(IslandData[c().SelectedIsland]))
                    end
                    
                    local island = Workspace.Mobs:WaitForChild(c().SelectedIsland)
                    local Closet = InRaya(island:GetChildren(), function(v) 
                        if not v:IsA("Model") then return false end 
                        local hum = v:FindFirstChild('Humanoid') or v:FindFirstChild('Enemy') 
                        return hum and hum.Health > 0 and c().AutoFarm and (c().SelectedMob == "All Mobs" or not c().SelectedMob or v.Name == c().SelectedMob) 
                    end) 
                    
                    if Closet then 
                        print("🎯 Attacking:", Closet.Name) 
                        repeat 
                            task.wait() 
                            Teleport(CFrame.new(Closet:GetPivot().Position - Vector3.new(0, 6, 0)) * CFrame.Angles(math.rad(90), 0, 0)) 
                            Attack() 
                            local hum = Closet:FindFirstChild('Humanoid') or Closet:FindFirstChild('Enemy') 
                        until not hum or hum.Health <= 0 or not c().AutoFarm 
                    end
                else 
                    local Closet = InRaya(GetAllEnemy(), function(v) 
                        local hum = v:FindFirstChild('Humanoid') or v:FindFirstChild('Enemy') 
                        return hum and hum.Health > 0 and c().AutoFarm 
                    end) 
                    
                    if Closet then 
                        print("🎯 Attacking:", Closet.Name) 
                        repeat 
                            task.wait() 
                            Teleport(CFrame.new(Closet:GetPivot().Position - Vector3.new(0, 6, 0)) * CFrame.Angles(math.rad(90), 0, 0)) 
                            Attack() 
                            local hum = Closet:FindFirstChild('Humanoid') or Closet:FindFirstChild('Enemy') 
                        until not hum or hum.Health <= 0 or not c().AutoFarm 
                    else 
                        task.wait(0.5)
                    end 
                end 
            end 
        end, function(d) warn(d) end) 
    end 
end

