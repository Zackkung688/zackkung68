local currentWeaponIndex = 1

--- 🗡️ AUTO EQUIP WEAPON (เปลี่ยนอาวุธอัตโนมัติ)
func['AutoEquipWeapon'] = function()
    while task.wait(c().WeaponSwapDelay or 5) do
        xpcall(function()
            if not c().AutoEquipWeapon then return end
            local weapons = {}

            for _, tool in ipairs(Backpack:GetChildren()) do
                if tool:IsA("Tool") then
                    table.insert(weapons, tool)
                end
            end
            if #weapons == 0 then return end

            if c().SelectedWeapons and #c().SelectedWeapons > 0 then
                local name = c().SelectedWeapons[currentWeaponIndex]
                local tool = Backpack:FindFirstChild(name)
                if tool then
                    Humanoid:EquipTool(tool)
                end
                currentWeaponIndex += 1
                if currentWeaponIndex > #c().SelectedWeapons then
                    currentWeaponIndex = 1
                end
            else
                currentWeaponIndex = ((currentWeaponIndex - 1) % #weapons) + 1
                Humanoid:EquipTool(weapons[currentWeaponIndex])
            end
        end, warn)
    end
end

