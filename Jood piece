--- แปลงเวลาเป็นรูปแบบพุทธศักราช (BE)
--- @return string เวลาในรูปแบบ DD/MM/YYYY BE, HH:MM
local function GetBETime()
    local t = os.date("!*t")
    t.year = t.year + 543
    return string.format(
        "%02d/%02d/%04d BE, %02d:%02d",
        t.day, t.month, t.year, t.hour, t.min
    )
end

--- ส่ง Webhook ไปยัง Discord
--- @param payload table ข้อมูล JSON ที่จะส่ง
local function PostWebhook(payload)
    if not c().WebhookURL or c().WebhookURL == "" then 
        return false, "Webhook URL not set"
    end
    
    local success, result = pcall(function()
        return request({
            Url = c().WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
    
    return success, result
end

