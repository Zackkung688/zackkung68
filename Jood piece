--- สร้าง Section ใน Tab
local function Section(Tab, Title)
    return Tab:Section({
        Title = Title,
        Box = false,
        TextSize = 17,
        Opened = true
    })
end

--- สร้าง Toggle พร้อมระบบ Threading
local function Toggle(def, Tab, Desc, Title, Key)
    local thread
    local t = Tab:Toggle({
        Title = Title,
        Desc = Desc,
        Value = c()[Key] or def,
        Callback = function(state)
            Config_Manager.S()[Key] = state
            c()[Key] = state

            if not state and thread then
                task.cancel(thread)
                thread = nil
            end

            if state and func[Key] then
                thread = task.spawn(func[Key])
            end

            Config_Manager.SG()
        end
    })

    if t then t.Callback(c()[Key] or def) end
    return t
end

--- สร้าง Slider
local function Slider(Tab, Title, Step, Min, Max, Def, Key)
    local s = Tab:Slider({
        Title = Title,
        Step = Step,
        Value = {Min = Min, Max = Max, Default = c()[Key] or Def},
        Callback = function(val)
            Config_Manager.S()[Key] = val
            c()[Key] = val
            Config_Manager.SG()
        end
    })

    if s then s.Callback(c()[Key] or Def) end
    return s
end

--- สร้าง Dropdown
local function Dropdown(Tab, Title, Key, Values, Multi)
    local d = Tab:Dropdown({
        Title = Title,
        Values = Values,
        Multi = Multi or false,
        AllowNone = false,
        Value = c()[Key] or (Multi and {} or Values[1]),
        Callback = function(v)
            Config_Manager.S()[Key] = v
            c()[Key] = v
            Config_Manager.SG()
        end
    })

    if d then d.Callback(c()[Key]) end
    return d
end

--- สร้าง Button
local function Button(Tab, Title, Desc, Callback)
    return Tab:Button({
        Title = Title,
        Desc = Desc,
        Callback = Callback
    })
end

