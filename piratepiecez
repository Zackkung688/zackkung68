-- ── Helpers ───────────────────────────────────
local function computeFarmCF(targetRoot)
    local p, d, mode = targetRoot.Position, CFG.FarmOffset or 6, CFG.FarmPosition or "Above"
    if mode == "Above"  then return CFrame.new(p + Vector3.new(0,d,0)) * CFrame.Angles(math.rad(-90),0,0) end
    if mode == "Below"  then return CFrame.lookAt(p + Vector3.new(0,-d,0), p) end
    if mode == "Behind" then return targetRoot.CFrame * CFrame.new(0,2,d) end
    return CFrame.new(p + Vector3.new(0,d,0)) * CFrame.Angles(math.rad(-90),0,0)
end

local function getEnemyFolder(island)
    local g = WS:FindFirstChild("Game"); if not g then return nil end
    local e = g:FindFirstChild("EnemyNpcs"); if not e then return nil end
    return e:FindFirstChild(island)
end

local function scanFolder(folder, name)
    local best, bestDist = nil, math.huge
    local myPos = (Root and Root.Position) or Vector3.zero
    local function tryModel(v)
        if v.Name ~= name or not v:IsA("Model") then return end
        local h = v:FindFirstChildOfClass("Humanoid")
        if not (h and h.Health > 0) then return end
        local r = getRoot(v)
        if r then
            local d = (r.Position - myPos).Magnitude
            if d < bestDist then bestDist=d; best=v end
        elseif not best then best=v end
    end
    for _, v in ipairs(folder:GetChildren())    do tryModel(v) end
    if not best then
        for _, v in ipairs(folder:GetDescendants()) do tryModel(v) end
    end
    return best
end

local function findFromList(nameList)
    for _, name in ipairs(nameList) do
        local island = IslandMap[name]; if not island then continue end
        local folder = getEnemyFolder(island); if not folder then continue end
        local npc    = scanFolder(folder, name)
        if npc then return npc, name, island end
    end
    return nil, nil, nil
end

local _lastTpIsland, _lastTpTime = nil, 0
local TP_COOLDOWN = 15

local function doFarmTeleport(island, targetName, targetModel)
    local now = tick()
    if island == _lastTpIsland and (now - _lastTpTime) < TP_COOLDOWN then return end
    FarmState.teleporting = true
    FarmState.target      = nil
    _lastTpIsland = island
    _lastTpTime   = now
    restoreCollisions()
    fireEvent("TeleportToIslandRequest", island)
    task.wait(2.5)
    if LP.Character then Root = LP.Character:FindFirstChild("HumanoidRootPart") or Root end
    if targetModel and Root then
        local r = waitForRoot(targetModel, 6)
        if r and Root then
            Root.CFrame = CFrame.new(r.Position + Vector3.new(0,6,6), r.Position)
            task.wait(0.2)
        end
    end
    FarmState.teleporting = false
end

