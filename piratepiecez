-- ── Equip (aggressive loop) ───────────────────
function Skills.DoEquip()
    pcall(function()
        local list = CFG.EquipList or {}
        if #list == 0 then return end
        for attempt = 1, 5 do
            local allEquipped = true
            for _, n in ipairs(list) do
                local equipped = LP.Character and LP.Character:FindFirstChild(n)
                if not equipped then
                    allEquipped = false
                    local t = LP.Backpack and LP.Backpack:FindFirstChild(n)
                    if t and LP.Character then
                        LP.Character:FindFirstChildOfClass("Humanoid"):EquipTool(t)
                        task.wait(0.25)
                    end
                end
            end
            if allEquipped then break end
            task.wait(0.5)
        end
    end)
end

