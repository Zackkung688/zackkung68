-- ── Infinite Tower ────────────────────────────
local function getTowerEnemies()
    local folder = WS:FindFirstChild("Infinite Tower")
    if not folder then return {} end
    local rt = folder:FindFirstChild("RuntimeEnemies")
    if not rt then return {} end
    local list = {}
    for _, v in ipairs(rt:GetChildren()) do
        if v:IsA("Model") then
            local h = v:FindFirstChildOfClass("Humanoid")
            if h and h.Health > 0 then
                table.insert(list, v)
            end
        end
    end
    return list
end

local function findNearestTowerEnemy()
    local enemies = getTowerEnemies()
    if #enemies == 0 then return nil end
    local best, bestDist = nil, math.huge
    local myPos = Root and Root.Position or Vector3.zero
    for _, v in ipairs(enemies) do
        local r = getRoot(v)
        if r then
            local d = (r.Position - myPos).Magnitude
            if d < bestDist then bestDist=d; best=v end
        end
    end
    return best
end

local _towerTarget     = nil
local _towerTeleporting = false

-- Heartbeat: lock on tower enemy
RunService.Heartbeat:Connect(function()
    if not CFG.AutoTower then return end
    if _towerTeleporting then return end
    local char = LP.Character; if not char then return end
    local hrp  = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    local tgt  = _towerTarget
    if tgt and isAlive(tgt) then
        local tr = getRoot(tgt)
        if tr then
            hrp.CFrame      = computeFarmCF(tr)
            hrp.Velocity    = Vector3.zero
            hrp.RotVelocity = Vector3.zero
            for _, v in pairs(char:GetChildren()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    else
        _towerTarget = nil
        restoreCollisions()
    end
end)

function Skills.TowerFarm()
    if _towerRunning then return end
    _towerRunning = true
    task.spawn(function()
        while CFG.AutoTower do
            if LP.Character then Root = LP.Character:FindFirstChild("HumanoidRootPart") or Root end

            -- Find alive enemy
            local enemy = findNearestTowerEnemy()
            if enemy and isAlive(enemy) then
                _towerTarget = enemy
                local now = tick()
                if now - _lastAttack >= (CFG.AttackSpeed or 0.2) then _lastAttack=now; hit() end
                if now - _lastSkill  >= (CFG.SkillSpeed  or 1.0) then _lastSkill =now; fireSkills() end
                task.wait(0.05)
            else
                _towerTarget = nil
                restoreCollisions()

                -- Check if tower ended (no enemies, try to handle end screen)
                local inTower = WS:FindFirstChild("Infinite Tower") ~= nil
                if inTower then
                    -- Pick modifier
                    pcall(function()
                        Events.InfiniteTowerModifierPick:FireServer(
                            CFG.TowerModifier or 1,
                            CFG.TowerModifier or 1,
                            CFG.TowerModifier or 1
                        )
                    end)
                    task.wait(1)

                    -- Handle end choice
                    local choice = CFG.TowerAfterEnd or "replay"
                    pcall(function()
                        Events.InfiniteTowerEndChoiceSelect:FireServer(choice)
                    end)

                    -- If lobby, re-enter after delay
                    if choice == "replay" then
                        task.wait(3)
                        fireEvent("InfiniteTowerEnterFromUi")
                        task.wait(5)
                    else
                        task.wait(8)
                        fireEvent("InfiniteTowerEnterFromUi")
                        task.wait(5)
                    end
                else
                    -- Not in tower, try to join
                    task.wait(2)
                    fireEvent("InfiniteTowerEnterFromUi")
                    task.wait(6)
                end
                task.wait(0.3)
            end
        end
        _towerTarget  = nil
        _towerRunning = false
        restoreCollisions()
    end)
end

