-- ── Farm ──────────────────────────────────────
function Skills.StartFarm()
    if _farmRunning then return end
    _farmRunning   = true
    _noTargetSince = nil
    task.spawn(function()
        while CFG.AutoFarm or CFG.AutoBossFarm do
            if FarmState.teleporting then task.wait(0.3); continue end
            if LP.Character then Root = LP.Character:FindFirstChild("HumanoidRootPart") or Root end
            local npc, name, island
            if CFG.AutoBossFarm and #(CFG.SelectedBosses or {}) > 0 then
                npc, name, island = findFromList(CFG.SelectedBosses)
            end
            if not npc and CFG.AutoFarm and #(CFG.SelectedMonsters or {}) > 0 then
                npc, name, island = findFromList(CFG.SelectedMonsters)
            end
            if npc and isAlive(npc) then
                _noTargetSince = nil
                local tRoot = getRoot(npc)
                local dist  = (tRoot and Root) and (Root.Position - tRoot.Position).Magnitude or math.huge
                if dist > 400 then
                    doFarmTeleport(island, name, npc)
                    if CFG.AutoBossFarm and #(CFG.SelectedBosses or {}) > 0 then
                        npc, name, island = findFromList(CFG.SelectedBosses)
                    end
                    if not npc and CFG.AutoFarm and #(CFG.SelectedMonsters or {}) > 0 then
                        npc, name, island = findFromList(CFG.SelectedMonsters)
                    end
                end
                if npc and isAlive(npc) then
                    FarmState.target = npc
                    FarmState.island = island
                    local now = tick()
                    if now - _lastAttack >= (CFG.AttackSpeed or 0.2) then _lastAttack=now; hit() end
                    if now - _lastSkill  >= (CFG.SkillSpeed  or 1.0) then _lastSkill =now; fireSkills() end
                end
            else
                FarmState.target = nil
                if not _noTargetSince then _noTargetSince = tick() end
                if tick() - _noTargetSince >= 5 then
                    _noTargetSince = nil
                    local dest = CFG.AutoBossFarm and CFG.SelectedBosses[1]
                             or (CFG.AutoFarm and CFG.SelectedMonsters[1])
                    if dest and IslandMap[dest] then
                        doFarmTeleport(IslandMap[dest], dest, nil)
                    end
                end
                task.wait(0.5)
            end
            task.wait(0.05)
        end
        restoreCollisions(); FarmState.target=nil; _farmRunning=false
    end)
end

-- Heartbeat: lock position + disable collision while farming
RunService.Heartbeat:Connect(function()
    if not (CFG.AutoFarm or CFG.AutoBossFarm) then return end
    if FarmState.teleporting then return end
    local char = LP.Character; if not char then return end
    local hrp  = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    local tgt  = FarmState.target
    if tgt and isAlive(tgt) then
        local tr = getRoot(tgt)
        if tr then
            hrp.CFrame      = computeFarmCF(tr)
            hrp.Velocity    = Vector3.zero
            hrp.RotVelocity = Vector3.zero
            for _, v in pairs(char:GetChildren()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    else
        FarmState.target = nil
        restoreCollisions()
    end
end)

-- ── Quest ─────────────────────────────────────
local function acceptQuest(name)
    pcall(function()
        local npcName = QuestNpcs[name]; if not npcName then return end
        local qGivers = WS.Game.ServiceNpcs.QuestGivers
        local model   = qGivers:FindFirstChild(npcName); if not model then return end
        local root    = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart"); if not root then return end
        local dist    = Root and (Root.Position - root.Position).Magnitude or math.huge
        if dist > 100 then
            local destIsland = QuestIsland[name]
            if destIsland then
                teleportIsland(destIsland); task.wait(2)
                if LP.Character then Root = LP.Character:FindFirstChild("HumanoidRootPart") or Root end
                model = qGivers:FindFirstChild(npcName); if not model then return end
                root  = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart"); if not root then return end
            end
        end
        Root.CFrame = CFrame.new(root.Position + (Root.Position - root.Position).Unit * 8 + Vector3.new(0,3,0), root.Position)
        task.wait(0.2)
        for _, v in pairs(model:GetDescendants()) do
            if v:IsA("ProximityPrompt") then fireproximityprompt(v,0); task.wait(0.15); break end
        end
        Remotes:WaitForChild("ToggleQuestLoop"):FireServer(1, 2)
    end)
end

function Skills.AutoQuest()
    while CFG.AutoQuest do
        local cur, max = getQuestProgress()
        if cur == nil or max == nil or max == 0 then
            acceptQuest(CFG.QuestSelected); task.wait(3)
        elseif cur >= max then
            acceptQuest(CFG.QuestSelected); task.wait(3)
        else
            task.wait(1.5)
        end
    end
end

