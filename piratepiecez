    Name = "xlinkx", Icon = "lucide:key", Args = { "PostSlug","ApiKey" },
    New = function(PostSlug, ApiKey)
        local function validateKey(key)
            if not key or key:gsub("%s+","") == "" then return false, "Please enter a key." end
            key = key:gsub("%s+","")
            local url = BASE_URL.."/api/keys/check"
                .."?post="..HttpService:UrlEncode(PostSlug)
                .."&key=" ..HttpService:UrlEncode(key)
                .."&hwid="..HttpService:UrlEncode(HWID)
            local ok, res = pcall(game.HttpGet, game, url, true)
            if not ok then return false, "Cannot connect to server." end
            local ok2, data = pcall(HttpService.JSONDecode, HttpService, res)
            if not ok2 then return false, "Bad response from server." end
            if data.status == "error" then return false, data.message or "Server error." end
            if not data.valid         then return false, data.message or "Key invalid or expired." end
            if data.hwid_bound and data.hwid_match == false then
                return false, "HWID mismatch — key bound to another device."
            end
            if not data.hwid_bound then
                local fn = request or (http and http.request) or (syn and syn.request)
                if fn then
                    pcall(fn, {
                        Url    = BASE_URL.."/api/keys/set-hwid", Method = "POST",
                        Headers = { ["Content-Type"] = "application/json" },
                        Body   = HttpService:JSONEncode({ post=PostSlug, api_key=ApiKey, key=key, hwid=HWID }),
                    })
                end
            end
            return true, "Key valid!"
        end
        return {
            Verify = validateKey,
            Copy   = function() setclipboard(BASE_URL.."/post/"..PostSlug) end,
        }
    end,
}


