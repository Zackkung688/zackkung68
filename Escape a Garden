        return game:GetService("RbxAnalyticsService"):GetClientId()
    end)
    return (ok and id and id ~= "") and id or tostring(lp.UserId)
end)()

local function checkKey(key)
    local url = BASE_URL .. "/api/keys/check"
        .. "?post=" .. HttpService:UrlEncode(POST_SLUG)
        .. "&key="  .. HttpService:UrlEncode(key)
        .. "&hwid=" .. HttpService:UrlEncode(HWID)
    local ok, res = pcall(game.HttpGet, game, url, true)
    if not ok then return false, "Cannot connect to server" end
    local ok2, data = pcall(HttpService.JSONDecode, HttpService, res)
    if not ok2 then return false, "Bad response" end
    if data.status == "error" then return false, data.message or "Server error" end
    if not data.valid then return false, data.message or "Key invalid or expired" end
    if data.hwid_bound and data.hwid_match == false then
        return false, "HWID mismatch — key bound to another device"
    end
    return true, data
end

local function bindHwid(key)
    local fn = request or (http and http.request) or (syn and syn.request)
    if not fn then return end
    pcall(fn, {
        Url     = BASE_URL .. "/api/keys/set-hwid",
        Method  = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body    = HttpService:JSONEncode({ post = POST_SLUG, api_key = API_KEY, key = key, hwid = HWID }),
    })
end

