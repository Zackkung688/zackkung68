task.spawn(function()
    local PathPlots = workspace
        :WaitForChild("World",     60)
        :WaitForChild("Shared",    60)
        :WaitForChild("PathPlots", 60)

    if not PathPlots then
        for i = 1, 11 do plotLabels[i]:Set("Plot " .. i .. " · ERROR") end
        return
    end

    while true do
        for i = 1, 11 do
            pcall(function()
                local slot   = PathPlots:FindFirstChild(tostring(i))
                local plants = slot and getPlantsInPlot(slot) or {}
                if #plants == 0 then
                    plotLabels[i]:Set("Plot " .. i .. " · empty")
                    return
                end
                local parts = {}
                for _, p in ipairs(plants) do
                    local name, rarity = parsePlantName(
                        p.gi:FindFirstChild("PlantName") and p.gi.PlantName.Text)
                    local prog = parseProgressValue(
                        p.gi:FindFirstChild("GrowingProgress") and p.gi.GrowingProgress.Text)
                    local mut = p.gi:FindFirstChild("Mutations") and p.gi.Mutations.Text or ""
                    local mutStr = mut ~= "" and (" · " .. mut) or ""
                    table.insert(parts, string.format(
                        "[p%d] %s [%s] %s %d%%%s",
                        p.idx, name, rarity, getProgressBar(prog), prog, mutStr
                    ))
                end
                plotLabels[i]:Set("Plot " .. i .. " · " .. table.concat(parts, "  |  "))
            end)
        end
        task.wait(0.5)
    end
end)

