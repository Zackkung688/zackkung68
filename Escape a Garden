                local cashBar     = rebirthFrame:FindFirstChild("CashBar")
                local amountLbl   = cashBar and cashBar:FindFirstChild("Amount")

                if nextRebirth then rebirthLabel:Set("Next Rebirth: "   .. tostring(nextRebirth.Text)) end
                if title       then rebirthWarning:Set("Requirement: " .. tostring(title.Text))       end

                -- เช็คว่าพอรีเบิดไหม เช่น "25K/250K"
                if Config.AutoRebirth and amountLbl then
                    local txt = tostring(amountLbl.Text)
                    local function parseK(s)
                        local n, suffix = s:match("(%d+%.?%d*)([KMBkmb]?)")
                        n = tonumber(n) or 0
                        suffix = suffix:upper()
                        if suffix == "K" then return n * 1e3
                        elseif suffix == "M" then return n * 1e6
                        elseif suffix == "B" then return n * 1e9
                        end
                        return n
                    end
                    local have, need = txt:match("^(.-)%s*/%s*(.-)$")
                    if have and need then
                        local haveN = parseK(have)
                        local needN = parseK(need)
                        if haveN >= needN then
                            fireRemote("RequestRebirth", {}, "\134")
                        end
                    end
                end
            end

            -- Auto Buy Speed
            if Config.AutoBuySpeed then
                fireRemote("BuyUpgrade", { "Speed" }, "\131")
            end
        end)
        task.wait(0.5)
    end
end)
