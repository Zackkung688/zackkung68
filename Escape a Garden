local function getProgressBar(pct)
    local filled = math.clamp(math.floor(pct / 10), 0, 10)
    local symbol = pct >= 80 and "█" or pct >= 50 and "▓" or "░"
    return string.rep(symbol, filled) .. string.rep("░", 10 - filled)
end

local function parsePlantName(text)
    if not text then return "?", "?" end
    local name, rarity = tostring(text):match("^(.-)%s*%((.-)%)%s*$")
    return name or tostring(text), rarity or "?"
end

local function parseProgressValue(text)
    return tonumber(tostring(text or ""):match("(%d+%.?%d*)%%")) or 0
end

local function getPlantsInPlot(slot)
    local plants = {}
    for i = 1, 10 do
        local plant = slot:FindFirstChild(tostring(i))
        if not plant then break end
        local gi = plant:FindFirstChild("Pivot") and plant.Pivot:FindFirstChild("GrowingInformatic")
        if gi then table.insert(plants, { idx = i, gi = gi }) end
    end
    return plants
end

